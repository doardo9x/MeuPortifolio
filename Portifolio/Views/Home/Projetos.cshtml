@{
    ViewData["Title"] = "Projetos";
}

<section class="inner-page">
    <h1 class="page-title">PROJETOS</h1>
    <p class="page-sub">Alguns dos projetos que desenvolvi.</p>

    <div class="projetos-grid">

        <div class="projeto-card">
            <div class="projeto-header">
                <span class="projeto-tag github">GitHub</span>
            </div>
            <h2>Meu GitHub</h2>
            <p>Aqui você encontra meus projetos e repositórios.</p>
            <div class="projeto-links">
                <a href="https://github.com/Doardo9x" target="_blank" class="btn-ghost">GitHub</a>
            </div>
        </div>
        <div class="projeto-card">
            <div class="projeto-header">
                <span class="projeto-tag ia">IA</span>
                <span class="projeto-tag groq">GROQ</span>
            </div>
            <h2>Inteligência Artificial</h2>
            <p>Aqui você pode acessar uma inteligencia artificial para tirar suas dúvidas.</p>
            <div class="projeto-links">
                <a class="btn-ghost" asp-controller="Ia" asp-action="Index">Abrir CHAT</a>
            </div>
        </div>
        <div class="projeto-card">
            <div class="projeto-header">
                <span class="projeto-tag">9xHype</span>
                <span class="projeto-tag net">.NET 10 MVC</span>
                <span class="projeto-tag sql">SQLite</span>
            </div>
            <h2>Loja Virtual - 9xHype</h2>
            <p>Essa é meu projeto de Tcc da minha loja online</p>
            <div class="projeto-links">
                <a asp-area="ninexhype" asp-controller="Home" asp-action="Index" class="btn-ghost">
                    Acessar Projeto
                </a>
            </div>
        </div>
        <div class="projeto-card">
            <div class="projeto-header">
                <span class="projeto-tag pokemon">POKÉMON</span>
                <span class="projeto-tag net">.NET 8 MVC</span>
                <span class="projeto-tag json">JSON</span>
            </div>
            <h2>Pokédex</h2>
            <p>Não poderia faltar a famosa pokédex né?</p>
            <div class="projeto-links">
                <a asp-area="pokedex" asp-controller="Home" asp-action="Index" class="btn-ghost">
                    Acessar Projeto
                </a>
            </div>
        </div>

        <!-- Novos cards são adicionados aqui -->

    </div>
</section>