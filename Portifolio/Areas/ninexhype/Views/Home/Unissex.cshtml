@model IEnumerable<Portifolio.Areas.NinexHype.Models.Produto>

<link rel="stylesheet" href="home.css">
<link rel="stylesheet" href="~/ninexhype-css/PagGeneros.css" />

@{
    ViewData["Title"] = "Produtos Unissex";
}
<div id="carouselExampleIndicators" class="carousel slide">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active"
            aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1"
            aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2"
            aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/ninexhype-img/FotosCarrossel/PagGeneros/7.png" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
            <img src="~/ninexhype-img/FotosCarrossel/PagGeneros/8.png" class="d-block w-100" alt="...">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<div>
    <h2 class="pTODOS normalText fs-1 w-100 center">PARA TODOS</h2>
</div>


@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center" role="alert">
        Nenhum produto disponível no momento.
    </div>
}
else
{
    <section class="contRoupa">
        <div class="carrosselRoupas">
            @foreach (var produto in Model)
            {
                <div class="card cardCarrossel" style="width: 12rem;">
                    <a asp-action="Produto" asp-route-id="@produto.Id">
                        <img class="card-img-top" src="@(produto.Fotos.Count == 0 
                                    ? "https://dummyimage.com/450x300/dee2e6/6c757d.jpg"
                                    : produto.Fotos[0].ArquivoFoto)" alt="@produto.Nome" />
                    </a>

                    <div class="card-body">
                        <h5 class="card-title nomeProdutoCarrossel">@produto.Nome</h5>
                        <p class="precoProduto card-text">R$ @produto.ValorVenda.ToString("N2")</p>
                    </div>
                </div>
            }
        </div>
    </section>
}
