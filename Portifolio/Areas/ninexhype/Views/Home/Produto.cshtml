    crossorigin="anonymous"></script>
<script src="https://kit.fontawesome.com/f950f409a7.js" crossorigin="anonymous"></script>
<script src="https://kit.fontawesome.com/f950f409a7.js" crossorigin="anonymous"></script>


<script src="~/ninexhype-js/PagProduto/CarrosselScript.js"></script>

<script src="~/ninexhype-js/PagProduto/scriptComentario.js"></script>