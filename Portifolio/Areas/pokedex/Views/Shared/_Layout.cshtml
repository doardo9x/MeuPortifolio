<!doctype html>
<html lang="pt-br">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Pokédex | @ViewData["title"] </title>

    <link rel="apple-touch-icon" href="~/pokedex-img/favicons/apple-touch-icon.png" sizes="180x180">
    <link rel="icon" href="~/pokedex-img/favicons/favicon-32x32.png" sizes="32x32" type="image/png">
    <link rel="icon" href="~/pokedex-img/favicons/favicon-16x16.png" sizes="16x16" type="image/png">
    <link rel="icon" href="~/pokedex-img/favicons/favicon.ico">

    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-gH2yIJqKdNHPEq0n4Mqa/HGKIhSkIHeL5AyhkYV8i59U5AR6csBvApHHNl/vI1Bx" crossorigin="anonymous">
    <link rel="stylesheet" href="~/pokedex-css/site.css" />

    <style>
        /* Estilos Globais do Layout */
        :root {
            --pokedex-red: #dc3545;
            --pokedex-dark-red: #8b0000;
            --pokedex-blue: #007bff;
        }

        body {
            background-color: #f0f0f0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Header Estilo Pokédex */
        .navbar-pokedex {
            background-color: var(--pokedex-red);
            border-bottom: 6px solid var(--pokedex-dark-red);
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        .navbar-brand {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 2px;
            text-shadow: 2px 2px 0px var(--pokedex-dark-red);
        }

        /* Detalhe da "Lente" da Pokédex no Header */
        .pokedex-lens {
            width: 40px;
            height: 40px;
            background: radial-gradient(circle at 30% 30%, #5cabff, #0056b3);
            border: 4px solid white;
            border-radius: 50%;
            margin-right: 15px;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
        }

        .pokedex-mini-lights {
            display: flex;
            gap: 5px;
            margin-left: 10px;
        }

        .light { width: 12px; height: 12px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.2); }
        .red { background: #ff0000; }
        .yellow { background: #ffff00; }
        .green { background: #00ff00; }

        /* Rodapé Tecnológico */
        footer {
            background: #333;
            color: #aaa !important;
            border-top: 5px solid var(--pokedex-red);
            margin-top: auto;
        }

        .btn-scroll-top {
            transition: transform 0.3s ease;
        }
        .btn-scroll-top:hover {
            transform: scale(1.2);
        }
    </style>
</head>

<body>
    <header>
        <div class="collapse" id="navbarHeader" style="background-color: #222;">
            <div class="container">
                <div class="row">
                    <div class="col-sm-8 col-md-7 py-4 text-white">
                        <h4 class="text-danger fw-bold">SYSTEM INFO</h4>
                        <p>
                            <strong>Unidade Pokédex v1.0</strong><br>
                            Módulo de pesquisa de criaturas desenvolvido em .NET 10.0 MVC. 
                            Arquitetura baseada em dados JSON com renderização dinâmica de tipos e sprites.
                        </p>
                    </div>
                    <div class="col-sm-4 offset-md-1 py-4 text-white">
                        <h4 class="text-danger fw-bold">LINKS</h4>
                        <ul class="list-unstyled">
                            <li><a href="https://github.com/doardo9x" class="text-white text-decoration-none">🌐 Repositório GitHub</a></li>
                            <li><a href="https://www.linkedin.com/in/doardo9x/" class="text-white">🔗 LinkedIn</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-dark navbar-pokedex shadow-sm">
            <div class="container d-flex justify-content-between">
                <a asp-action="Index" class="navbar-brand d-flex align-items-center">
                    <div class="pokedex-lens"></div>
                    <div class="d-none d-sm-block">
                        <strong>POKÉDEX</strong>
                    </div>
                    <div class="pokedex-mini-lights d-none d-md-flex">
                        <div class="light red"></div>
                        <div class="light yellow"></div>
                        <div class="light green"></div>
                    </div>
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarHeader"
                    aria-controls="navbarHeader" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="py-4">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-0 fw-bold text-white">Pokédex v1.0</p>
                    <small>Desenvolvido por Eduardo Ribeiro &copy; @DateTime.Now.Year</small>
                </div>
                
                <a href="#" class="btn-scroll-top">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="#dc3545"
                        class="bi bi-arrow-up-square-fill" viewBox="0 0 16 16">
                        <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm6.5 11.5a.5.5 0 0 1-1 0V5.707L5.354 7.854a.5.5 0 1 1-.708-.708l3-3a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 5.707V11.5z" />
                    </svg>
                </a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-A3rJD856KowSb7dwlZdYEkO39Gagi7vIsF0jrRAoQmDKKtQBHUuLZ9AsSv4jD4Xa"
        crossorigin="anonymous"></script>
    <script src="~/pokedex-lib/jquery/dist/jquery.min.js"></script>
    <script src="~/pokedex-js/site.js" asp-append-version="true"></script> 
</body>
</html>