@model List<Pokemon>
@{
    ViewData["Title"] = "Pokédex Home";
    var tipos = (List<Tipo>)ViewData["Tipos"];
    
    // Função auxiliar para pegar a cor do tipo principal do Pokémon para o fundo do card
    string ObterCorPrincipal(List<string> pokemonTipos)
    {
        if (pokemonTipos == null || !pokemonTipos.Any()) return "#lightgray";
        var primeiroTipo = pokemonTipos.First();
        return tipos.Where(t => t.Nome == primeiroTipo).Select(t => t.Cor).FirstOrDefault() ?? "#lightgray";
    }

    string ObterCorDoTipo(string nomeTipo)
    {
         return tipos.Where(t => t.Nome == nomeTipo).Select(t => t.Cor).FirstOrDefault() ?? "#777";
    }
}

<section class="pt-5 pb-4 text-center container-fluid jumbotron-pokedex mb-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="pokedex-title mb-3">Pokédex</h1>
            <p class="lead text-muted mb-4">Selecione um tipo para filtrar ou clique no Pokémon para detalhes.</p>
            
            <div class="filter-group shadow-sm">
                <button id="btn-all" class="btn btn-filter active bg-dark text-white" onclick="filter('all')">
                    Ver Todos
                </button>
                @foreach (var tipo in tipos)
                {
                    <button id="btn-@tipo.Nome" class="btn btn-filter text-white"
                            style="background-color:@tipo.Cor" onclick="filter('@tipo.Nome')">
                        @tipo.Nome
                    </button>
                }
            </div>
        </div>
    </div>
</section>

<div class="album py-3 album-pokedex">
    <div class="container">

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var pokemon in Model)
            {
                var corPrincipal = ObterCorPrincipal(pokemon.Tipo);
                
                <div class="col col-pokedex pokemon-card-container">
                    <div class="card pokedex-card h-100 @string.Join(' ', pokemon.Tipo)" 
                         onclick="window.location = 'Pokedex/Home/Details/@pokemon.Numero'"
                         style="--bg-type-color: @corPrincipal;">
                        
                        <div class="pokedex-card-img-container">
                            <img src="@pokemon.Imagem" class="img-fluid" alt="@pokemon.Nome" loading="lazy" />
                        </div>

                        <div class="card-body pokedex-card-body">
                            <span class="pokemon-number">Nº @pokemon.Numero.ToString("000")</span>
                            <h4 class="card-title pokemon-name">@pokemon.Nome</h4>
                            
                            <div class="pokedex-badges mt-2">
                                @foreach (var tipoNome in pokemon.Tipo)
                                {
                                    <span class="badge-tipo" style="background-color: @ObterCorDoTipo(tipoNome)">
                                        @tipoNome
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                }
            
            <div id="zeroPokemon" class="col-lg-12 text-center pokedex-error d-none my-5">
                <img src="/pokedex-img/psyduck-confused.png" alt="Não encontrado" class="mb-3" style="max-width: 150px;"/>
                <h2 class="my-3">Ops! Nenhum Pokémon Encontrado</h2>
                <p class="lead">Tente selecionar outro tipo ou "Ver Todos".</p>
            </div>
        </div>

    </div>
</div>