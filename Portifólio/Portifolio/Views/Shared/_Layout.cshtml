<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Eduardo Ribeiro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Arvo:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>

    <!-- Background -->
    <canvas id="particles-bg"></canvas>
    <div class="blur-cursor"></div>

    <!-- Botão abrir menu -->
    <button class="open-btn" onclick="openMenu()">☰ Menu</button>

    <!-- Menu lateral -->
    <nav id="sidebar">
        <button class="close-btn" onclick="closeMenu()">×</button>
        <ul>
            <li><a asp-controller="Home"    asp-action="Index">Início</a></li>
            <li><a asp-controller="Home"    asp-action="Projetos">Projetos</a></li>
            <li><a asp-controller="Ia"      asp-action="Index">Inteligência Artificial</a></li>
            <li><a asp-controller="Home"    asp-action="Contato">Contato</a></li>
        </ul>
    </nav>

    <!-- Conteúdo principal -->
    <main id="content" class="page-content surgindo">
        @RenderBody()
    </main>

    <script src="~/js/particles.js" asp-append-version="true"></script>
    <script src="~/js/site.js"      asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
