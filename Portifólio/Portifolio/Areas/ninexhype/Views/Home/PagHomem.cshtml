@model Portifolio.Areas.NinexHype.ViewModels.IndexVM
@{
    ViewData["Title"] = "Homens";

}
<link rel="stylesheet" href="~/ninexhype-css/PagGeneros.css" />
<div id="carouselExampleIndicators" class="carousel slide">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active"
            aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1"
            aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2"
            aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
<div class="carousel-item active">
            <img src="~/ninexhype-img/FotosCarrossel/PagGeneros/5.png" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
            <img src="~/ninexhype-img/FotosCarrossel/PagGeneros/4.png" class="d-block w-100" alt="...">
        </div>
        <div class="carousel-item">
            <img src="~/ninexhype-img/FotosCarrossel/PagGeneros/3.png" class="d-block w-100" alt="...">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators"
        data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<section class="contRoupa">
    <div class="carrosselRoupas">
        <div class="Linha center">
            <p class="LinhaTitulo fs-1 center">Sneakers</p>
        </div>

        @foreach (var tipo in Model.TiposRoupa.Where(tr => tr.Id == 2))
        {

            var produtosTipo = tipo.Categorias.SelectMany(c => c.Produtos);

            @foreach (var produto in produtosTipo)
            {
                <div class="card cardCarrossel" style="width: 12rem;">
                    <a asp-action="Produto" asp-route-id="@produto.Id">
                        <img src="@(produto.Fotos.Count <= 0 
                                                             ? "https://dummyimage.com/450x300/dee2e6/6c757d.jpg" 
                                                             : produto.Fotos[0].ArquivoFoto)" alt="@produto.Nome" class="card-img-top">
                    </a>
                    <div class="card-body">
                        <p class="card-text nomeProdutoCarrossel">@produto.Nome</p>
                        <p class="card-text precoProduto">R$ @produto.ValorVenda.ToString("N2")</p>
                    </div>
                </div>
            }
        }

        <div class="LinhaEsq">
            <p class="LinhaTitulo fs-1 center">Roupas</p>
        </div>
        @foreach (var tipo in Model.TiposRoupa.Where(tr => tr.Id == 1))
        {

            var produtosTipo = tipo.Categorias.SelectMany(c => c.Produtos);

            @foreach (var produto in produtosTipo)
            {
                <div class="card cardCarrossel" style="width: 12rem;">
                    <a asp-action="Produto" asp-route-id="@produto.Id">
                        <img src="@(produto.Fotos.Count <= 0 
                                                             ? "https://dummyimage.com/450x300/dee2e6/6c757d.jpg" 
                                                             : produto.Fotos[0].ArquivoFoto)" alt="@produto.Nome" class="card-img-top">
                    </a>
                    <div class="card-body">
                        <p class="card-text nomeProdutoCarrossel">@produto.Nome</p>
                        <p class="card-text precoProduto">R$ @produto.ValorVenda.ToString("N2")</p>
                    </div>
                </div>
            }
        }



    </div>
</section>